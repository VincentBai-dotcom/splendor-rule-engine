{
  "name": "splendor-rule-engine",
  "private": true,
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@eslint/json": "^0.14.0",
    "@eslint/markdown": "^7.5.1",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "3.7.4",
    "typescript-eslint": "^8.51.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,mts,cts,json,jsonc,json5,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
